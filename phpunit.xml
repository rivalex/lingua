<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true">
    <testsuites>
        <testsuite name="Unit">
            <file>tests/Unit/helpersTest.php</file>
        </testsuite>
        <testsuite name="Feature">
            <file>tests/Feature/InitializeTest.php</file>
            <!-- Artisan Commands -->
            <file>tests/Feature/Commands/SyncToDatabaseCommandTest.php</file>
            <file>tests/Feature/Commands/SyncToLocalCommandTest.php</file>
            <file>tests/Feature/Commands/UpdateLangCommandTest.php</file>
            <file>tests/Feature/Commands/AddLangCommandTest.php</file>
            <file>tests/Feature/Commands/RemoveLangCommandTest.php</file>
            <!-- Languages Management-->
            <file>tests/Feature/Livewire/LanguagesTest.php</file>
            <!-- Languages actions -->
            <file>tests/Feature/Livewire/Language/TableTest.php</file>
            <file>tests/Feature/Livewire/Language/RowTest.php</file>
            <file>tests/Feature/Livewire/Language/CreateTest.php</file>
            <file>tests/Feature/Livewire/Language/SortTest.php</file>
            <file>tests/Feature/Livewire/Language/DeleteTest.php</file>
            <file>tests/Feature/Livewire/Language/SetDefaultTest.php</file>
            <!-- Language selector -->
            <file>tests/Feature/Livewire/LanguageSelectorTest.php</file>
            <file>tests/Feature/Livewire/Selector/IconTest.php</file>
            <file>tests/Feature/Livewire/HeadlessLanguageSelectorTest.php</file>
            <!-- Translations -->
            <file>tests/Feature/Livewire/TranslationsTest.php</file>
            <!-- Translation components -->
            <file>tests/Feature/Livewire/Translation/CreateTest.php</file>
            <file>tests/Feature/Livewire/Translation/UpdateTest.php</file>
            <file>tests/Feature/Livewire/Translation/DeleteTest.php</file>
            <file>tests/Feature/Livewire/Translation/RowTest.php</file>
            <!-- Blade anonymous components -->
            <file>tests/Feature/Components/BladeComponentsTest.php</file>
            <!-- Sync -->
            <file>tests/Feature/Sync/SyncToDatabaseTest.php</file>
        </testsuite>
    </testsuites>

    <logging>
        <junit outputFile="build/report.junit.xml"/>
    </logging>
    <source>
        <include>
            <directory>./src</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
